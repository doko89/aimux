# ============================================================
# AI API Gateway Configuration
# ============================================================

# ---- Gateway Settings ----
GATEWAY_PORT=8080
GATEWAY_HOST=0.0.0.0
DEBUG=false

# ---- Routing Strategy ----
# Options: round_robin, fallback, weighted, least_latency
ROUTING_STRATEGY=weighted
FALLBACK_ON_ERROR=true
MAX_RETRIES=2

# ---- Model Aggregation YAML ----
# Path to aggregation.yaml for virtual model definitions.
# See aggregation.example.yaml for the format.
CONFIG_FILE=aggregation.yaml

# ---- Provider: OpenAI ----
OPENAI_ENABLED=true
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_WEIGHT=50
OPENAI_PRIORITY=1
OPENAI_TIMEOUT=120
OPENAI_MAX_RPM=60

# ---- Provider: Anthropic (Passthrough) ----
ANTHROPIC_ENABLED=true
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_WEIGHT=30
ANTHROPIC_PRIORITY=2
ANTHROPIC_PASSTHROUGH=false

# ---- Provider: DeepSeek ----
DEEPSEEK_ENABLED=false
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_WEIGHT=20
DEEPSEEK_PRIORITY=3

# ---- Provider: OpenRouter ----
OPENROUTER_ENABLED=false
OPENROUTER_API_KEY=sk-or-xxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ---- Provider: Ollama (Local) ----
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:70b

# ---- Provider: Mimo (OpenAI-compatible) ----
MIMO_ENABLED=true
MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_API_KEY=your-mimo-key
MIMO_MODEL=mimo-v2.5-pro
MIMO_WEIGHT=40
MIMO_PRIORITY=3

# ---- Provider: OpenCode (OpenAI-compatible, auto model discovery) ----
OPENCODE_ENABLED=true
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_API_KEY=your-opencode-key
# When AUTO_MODEL=true the gateway queries /models and picks a free model,
# so OPENCODE_MODEL can be left empty.
OPENCODE_AUTO_MODEL=true
OPENCODE_WEIGHT=40
OPENCODE_PRIORITY=4

# ---- Additional generic OpenAI-compatible providers ----
# Comma-separated list of extra provider names (uppercase env prefix per name).
# EXTRA_PROVIDERS=mycustom
# MYCUSTOM_BASE_URL=https://example.com/v1
# MYCUSTOM_API_KEY=sk-xxx
# MYCUSTOM_MODEL=some-model
# MYCUSTOM_WEIGHT=10
# MYCUSTOM_PRIORITY=5
# MYCUSTOM_AUTO_MODEL=false

# ---- Model Mapping ----
BIG_MODEL=gpt-4o
MIDDLE_MODEL=gpt-4o
SMALL_MODEL=gpt-4o-mini

# ---- Circuit Breaker ----
FAILURE_THRESHOLD=5
COOLDOWN_SECONDS=60
HEALTH_CHECK_INTERVAL=30

# ---- Rate Limiting ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=100
RATE_LIMIT_BURST=20

# ---- Client Authentication ----
# JSON array or comma-separated list of valid client keys.
# Empty = allow all clients (dev only).
VALID_API_KEYS=["your-client-key-1","your-client-key-2"]
